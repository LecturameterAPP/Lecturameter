<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    cloud backup: backs up SharedPreferences to Google Drive.
    device_transfer: includes data when transferring to a new device.
-->
<data-extraction-rules>
    <!-- A6: SOLO viaja lecturameter.xml. lecturameter_pro_local.xml (trial y lockout del
         canje) no está incluido y por tanto no va ni a la nube ni al traslado de dispositivo;
         lint prohíbe excluir un path no incluido, por eso basta con no incluirlo. -->
    <cloud-backup>
        <include domain="sharedpref" path="lecturameter.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="lecturameter.xml" />
    </device-transfer>
</data-extraction-rules>
