<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    cloud backup: backs up SharedPreferences to Google Drive.
    device_transfer: includes data when transferring to a new device.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="lecturameter.xml" />
        <!-- A6: trial y lockout aparte, nunca a la nube (evita reiniciar la prueba gratis). -->
        <exclude domain="sharedpref" path="lecturameter_pro_local.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="lecturameter.xml" />
        <!-- A6: tampoco viaja en la transferencia a un dispositivo nuevo. -->
        <exclude domain="sharedpref" path="lecturameter_pro_local.xml" />
    </device-transfer>
</data-extraction-rules>
