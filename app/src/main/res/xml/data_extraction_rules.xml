<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    cloud backup: backs up SharedPreferences to Google Drive.
    device_transfer: includes data when transferring to a new device.
-->
<data-extraction-rules>
    <!-- C1 (19-07): SOLO viaja lecturameter.xml, que ahora incluye el estado del trial
         (pro_trial_used y su ventana). Dejarlo fuera del backup NO impedía reiniciar la
         prueba: la permitía, porque al reinstalar la clave nacía a false. Ver ProState.kt.
         lecturameter_pro_local.xml (solo contadores del canje) sigue sin incluirse; lint
         prohíbe excluir un path no incluido, por eso basta con no incluirlo. -->
    <cloud-backup>
        <include domain="sharedpref" path="lecturameter.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="lecturameter.xml" />
    </device-transfer>
</data-extraction-rules>
