<?xml version="1.0" encoding="utf-8"?>
<!--
    Android Auto Backup rules (API 23-30).
    Includes all SharedPreferences (libros, sesiones, wrapped_history, dark_mode).
    Excludes the cache dir (temp CSV/JSON exports).
-->
<full-backup-content>
    <include domain="sharedpref" path="lecturameter.xml" />
    <!-- A6: el trial y el lockout del canje viven aparte y NO se respaldan, para que
         reinstalar no reinicie ni reactive la prueba gratis desde un backup viejo. -->
    <exclude domain="sharedpref" path="lecturameter_pro_local.xml" />
</full-backup-content>
