<?xml version="1.0" encoding="utf-8"?>
<!-- D-015: icono del tema Cuero para el selector — propuesta 1 "tapa con marco" en versión
     SIMÉTRICA (filete vertical grueso a AMBOS lados), elegida por Víctor 16-07 noche.
     Réplica del SVG del mockup mockup_tema_cuero.html. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Tapa: rect 5,3 → 19,21 con esquinas 2 -->
    <path
        android:fillColor="#4A3115"
        android:strokeColor="#D9AC5C"
        android:strokeWidth="1.4"
        android:pathData="M7,3 L17,3 A2,2 0 0 1 19,5 L19,19 A2,2 0 0 1 17,21 L7,21 A2,2 0 0 1 5,19 L5,5 A2,2 0 0 1 7,3 Z" />
    <!-- Marco interior: rect 7.5,5.5 → 16.5,18.5 con esquinas 1 -->
    <path
        android:strokeColor="#D9AC5C"
        android:strokeWidth="1"
        android:strokeAlpha="0.8"
        android:pathData="M8.5,5.5 L15.5,5.5 A1,1 0 0 1 16.5,6.5 L16.5,17.5 A1,1 0 0 1 15.5,18.5 L8.5,18.5 A1,1 0 0 1 7.5,17.5 L7.5,6.5 A1,1 0 0 1 8.5,5.5 Z" />
    <!-- Filete vertical grueso a ambos lados (versión simétrica) -->
    <path
        android:strokeColor="#D9AC5C"
        android:strokeWidth="2.2"
        android:pathData="M5,3 L5,21" />
    <path
        android:strokeColor="#D9AC5C"
        android:strokeWidth="2.2"
        android:pathData="M19,3 L19,21" />
</vector>
