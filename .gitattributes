# Normalize line endings
* text=auto

# Source files: LF
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.html text eol=lf
*.md text eol=lf
*.pro text eol=lf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.jar binary
*.keystore binary
*.jks binary
